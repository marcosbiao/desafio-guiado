import { describe, it, expect, vi, beforeEach } from 'vitest';
import request from 'supertest';
import { createServer } from '../../../server';
import { analyzeCodeWithGeminiServer } from '../analysis';

// Polyfill para TextEncoder/TextDecoder se necessário no ambiente de teste
if (typeof TextEncoder === 'undefined') {
  const { TextEncoder, TextDecoder } = require('util');
  global.TextEncoder = TextEncoder;
  global.TextDecoder = TextDecoder;
}

vi.mock('../analysis');

describe.skip('API de Análise', () => {
  let app: any;

  beforeEach(async () => {
    vi.clearAllMocks();
    app = await createServer();
  });

  it('deve retornar 400 para payload inválido (código vazio)', async () => {
    const response = await request(app)
      .post('/api/analyze')
      .send({ code: '', challengeId: '1' });

    expect(response.status).toBe(400);
    expect(response.body.ok).toBe(false);
    expect(response.body.error).toBe('INVALID_INPUT');
  });

  it('deve retornar 404 para desafio não encontrado', async () => {
    const response = await request(app)
      .post('/api/analyze')
      .send({ code: 'int main() {}', challengeId: 'non-existent' });

    expect(response.status).toBe(404);
    expect(response.body.error).toBe('CHALLENGE_NOT_FOUND');
  });

  it('deve retornar 200 e os dados da análise para uma requisição válida', async () => {
    const mockResult = { category: 'solução adequada', feedback: { nextStep: 'Parabéns' } };
    vi.mocked(analyzeCodeWithGeminiServer).mockResolvedValue(mockResult as any);

    const response = await request(app)
      .post('/api/analyze')
      .send({ 
        code: 'int main() {}', 
        challengeId: 'desafio1_condicionais_basico',
        userId: 'user-123'
      });

    expect(response.status).toBe(200);
    expect(response.body.ok).toBe(true);
    expect(response.body.data).toEqual(mockResult);
  });

  it('deve retornar 500 quando o Gemini falha', async () => {
    vi.mocked(analyzeCodeWithGeminiServer).mockRejectedValue(new Error('Gemini Error'));

    const response = await request(app)
      .post('/api/analyze')
      .send({ 
        code: 'int main() {}', 
        challengeId: 'desafio1_condicionais_basico'
      });

    expect(response.status).toBe(500);
    expect(response.body.error).toBe('INTERNAL_ERROR');
  });
});
