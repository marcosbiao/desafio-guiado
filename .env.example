# Judge0 Configuration
# URL padrão: https://ce.judge0.com (instância pública gratuita)
# Outras opções: https://judge0-ce.p.rapidapi.com (via RapidAPI)
JUDGE0_API_URL=https://ce.judge0.com

# Opcional para instâncias públicas. Obrigatório para RapidAPI ou instâncias privadas.
# Se usar RapidAPI, a chave deve ser a sua API Key da RapidAPI.
# Se usar Judge0 CE direto, a chave deve ser o seu X-Auth-Token.
JUDGE0_API_KEY=

# Gemini Configuration
GEMINI_API_KEY=
